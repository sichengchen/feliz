# Linear API key (required)
# Get yours at https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# GitHub personal access token (required, needs `repo` scope)
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Git identity for commits
GIT_AUTHOR_NAME=Feliz Bot
GIT_AUTHOR_EMAIL=feliz@example.com

# Agent API keys (optional — prefer OAuth via `feliz init` instead)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
