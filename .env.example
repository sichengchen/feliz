# Linear OAuth token (required)
# Obtain via: feliz auth linear
# Or create an OAuth app at https://linear.app/settings/api/applications/new
#   - Set actor=app for bot identity
#   - Required scopes: app:mentionable, app:assignable, read, write, issues:create
#   - Set callback URL to http://localhost:8374/auth/callback
LINEAR_OAUTH_TOKEN=lin_oauth_...

# GitHub personal access token (required, needs `repo` scope)
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Git identity for commits made by Feliz
GIT_AUTHOR_NAME=Feliz Bot
GIT_AUTHOR_EMAIL=feliz@example.com

# Agent API keys (optional — prefer agent OAuth via `feliz agent login <name>`)
# Claude Code: run `claude login` inside container, or set:
# ANTHROPIC_API_KEY=sk-ant-...
# Codex: run `codex login` inside container, or set:
# OPENAI_API_KEY=sk-...
