# Copy this file and fill values before running:
#   - scripts/e2e-smoke.sh
#   - scripts/e2e-real.sh

# Required for configs that use linear.api_key: $LINEAR_API_KEY
LINEAR_API_KEY=lin_api_replace_me

# Recommended for publish-related checks
GITHUB_TOKEN=ghp_replace_me

# Optional: pick one agent credential path if needed by your agent CLI
# OPENAI_API_KEY=sk_replace_me
# ANTHROPIC_API_KEY=sk-ant_replace_me

# Optional defaults consumed by scripts/e2e-smoke.sh
E2E_CONFIG_PATH=/tmp/feliz-e2e/feliz.yml
E2E_REPORT_PATH=/tmp/feliz-e2e-smoke-report.json

# Optional defaults consumed by scripts/e2e-real.sh
E2E_GH_OWNER=github-user-or-org
E2E_REPO_NAME=feliz-e2e-sandbox
E2E_LINEAR_PROJECT=Feliz E2E Test
E2E_AGENT_ADAPTER=codex
E2E_GH_VISIBILITY=private
E2E_WORK_DIR=/tmp/feliz-e2e
